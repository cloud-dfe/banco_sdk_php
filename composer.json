{
    "name": "cloud-dfe/banco-sdk-php",
    "type": "library",
    "description": "SDK para API integrabancos",
    "license": "private",
    "authors": [
        {
            "name": "Roberto L. Machado",
            "email": "linux.rlm@gmail.com"
        },
        {
            "name": "Cleiton Perin",
            "email": "cprein20@gmail.com"
        }
    ],
    "repositories": [
    ],
    "require": {
        "php": ">= 8.3",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "CloudDFe\\BancoSdk\\": "src/"
        }
    },
    "autoload-dev":{
        "psr-4": {
            "CloudDFe\\BancoSdk\\": "tests/"
        }
    },
    "scripts":{
        "phpcbf": "vendor/bin/phpcbf --standard=psr2 src",
        "phpcs": "vendor/bin/phpcs --standard=psr2 src",
        "phpstan": "vendor/bin/phpstan analyse src/ --level 1"
    },
    "extra": {
        "branch-alias": {
            "v1.0": "1.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
